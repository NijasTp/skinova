<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        body {
            background-color: #1a1d21;
            color: #ffffff;
        }

        .container-fluid {
            display: flex;
            min-height: 100vh;
        }

        .main-content {
            flex: 1;
            padding: 2rem;
        }

        .search-bar {
            width: 100%;
            max-width: 600px;
            margin: 0 auto 2rem;
            position: relative;
        }

        .search-input {
            width: 100%;
            padding: 0.75rem 1rem 0.75rem 2.5rem;
            background-color: #2d3139;
            border: none;
            border-radius: 0.5rem;
            color: white;
            font-size: 0.875rem;
        }

        .search-icon {
            position: absolute;
            left: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            color: #6b7280;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        h1 {
            font-size: 2rem;
            font-weight: 600;
        }

        .btn-add-user {
            background-color: #4fd1c5;
            color: #1a1d21;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 0.375rem;
            font-weight: 600;
            cursor: pointer;
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 1rem;
        }

        th, td {
            padding: 1rem;
            text-align: left;
            border-bottom: 1px solid #2d3139;
        }

        th {
            background-color: #2d3139;
            color: #9ca3af;
            font-weight: 500;
        }

        .user-image {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
        }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
            justify-content: flex-end;
        }

        .btn {
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            font-size: 0.875rem;
            cursor: pointer;
        }

        .btn-danger {
            background-color: #ef4444;
            color: white;
        }

        .btn-success {
            background-color: #10b981;
            color: white;
        }

        .action-icon {
            color: #9ca3af;
            text-decoration: none;
        }

        .pagination-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1rem;
        }

        .pagination {
            display: flex;
            list-style-type: none;
        }

        .page-item {
            margin: 0 0.25rem;
        }

        .page-link {
            display: block;
            padding: 0.5rem 0.75rem;
            color: #9ca3af;
            text-decoration: none;
            background-color: #2d3139;
            border-radius: 0.25rem;
        }

        .page-item.active .page-link {
            background-color: #4fd1c5;
            color: #1a1d21;
        }
                /* Aside Styles */
                .aside {
            width: 240px;
            background-color: #1a1d21;
            padding: 1.5rem 1rem;
            height: 100vh;
            border-right: 1px solid #2d3139;
        }

        .aside .logo {
            font-size: 1.75rem;
            font-weight: 500;
            color: #ffffff;
            margin-bottom: 3rem;
            padding-left: 0.5rem;
        }

        .aside .nav-menu {
            display: flex;
            flex-direction: column;
        }

        .aside .nav-item {
            display: flex;
            align-items: center;
            padding: 0.75rem 0.5rem;
            color: #6b7280;
            text-decoration: none;
            border-radius: 0.375rem;
            transition: all 0.2s;
            font-size: 1rem;
        }

        .aside .nav-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }

        .aside .nav-item.active {
            color: #ffffff;
        }

        .aside .nav-icon {
            display: flex;
            align-items: center;
            width: 24px;
            height: 24px;
            margin-right: 0.75rem;
        }

        .aside .nav-icon svg {
            width: 20px;
            height: 20px;
        }

        .aside .nav-item.logout {
            background-color: #ef4444;
            color: white;
            font-weight: bold;
        }

        .aside .nav-item.logout:hover {
            background-color: #dc2626;
        }

        /* Logout Form Styles */
        .aside .logout-form {
            display: block;
            width: 100%;
            text-decoration: none;
            color: inherit;
        }

        .aside .logout-button {
            display: flex;
            align-items: center;
            width: 100%;
            padding: 0.75rem 0.5rem;
            background: none;
            border: none;
            color: inherit;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.2s;
        }

        .aside .logout-button:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }

        .aside .logout-button .nav-icon {
            margin-right: 0.75rem;
        }

        .aside .logout-button .nav-text {
            flex: 1;
        }
        .sidebar {
            width: 240px;
            background-color: #1a1d21;
            padding: 1.5rem 1rem;
            height: 100vh;
            border-right: 1px solid #2d3139;
        }

        .logo {
            font-size: 1.75rem;
            font-weight: 500;
            color: #ffffff;
            margin-bottom: 3rem;
            padding-left: 0.5rem;
        }

        .nav-menu {
            display: flex;
            flex-direction: column;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 0.75rem 0.5rem;
            color: #6b7280;
            text-decoration: none;
            border-radius: 0.375rem;
            transition: all 0.2s;
            font-size: 1rem;
        }

        .nav-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }

        .nav-item.active {
            color: #ffffff;
        }

        .nav-icon {
            display: flex;
            align-items: center;
            width: 24px;
            height: 24px;
            margin-right: 0.75rem;
        }

        .nav-icon svg {
            width: 20px;
            height: 20px;
        }

        .nav-item.logout {
            background-color: #ef4444;
            color: white;
            font-weight: bold;
        }

        .nav-item.logout:hover {
            background-color: #dc2626;
        }


        @media (max-width: 768px) {
            .header {
                flex-direction: column;
                align-items: flex-start;
            }

            .btn-add-user {
                margin-top: 1rem;
            }

            .pagination-container {
                flex-direction: column;
                align-items: flex-start;
            }

            .pagination {
                margin-top: 1rem;
            }
        }

    </style>

</head>
<body>
    <div class="container-fluid">
       <aside class="sidebar">
            <div class="logo">Skinova</div>
            <nav class="nav-menu">
                <a href="/admin/dashboard" class="nav-item">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 12l9-9 9 9"></path>
                            <path d="M4 10v10a2 2 0 002 2h4v-6h4v6h4a2 2 0 002-2V10"></path>
                        </svg>
                    </span>
                    <span class="nav-text">Dashboard</span>
                </a>
                <a href="/admin/products" class="nav-item">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                            <path d="M8 21h8"></path>
                            <path d="M12 17v4"></path>
                        </svg>
                    </span>
                    <span class="nav-text">Products</span>
                </a>
                <a href="/admin/orders" class="nav-item">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 3h18"></path>
                            <path d="M7 10h10"></path>
                            <path d="M7 15h6"></path>
                            <rect x="5" y="6" width="14" height="14" rx="2"></rect>
                        </svg>
                    </span>
                    <span class="nav-text">Orders</span>
                </a>
                <a href="/admin/users" class="nav-item">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="8" r="4"></circle>
                            <path d="M6 21v-2a4 4 0 014-4h4a4 4 0 014 4v2"></path>
                        </svg>
                    </span>
                    <span class="nav-text">Users</span>
                </a>
                <a href="/admin/categories" class="nav-item">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7"></rect>
                            <rect x="14" y="3" width="7" height="7"></rect>
                            <rect x="14" y="14" width="7" height="7"></rect>
                            <rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                    </span>
                    <span class="nav-text">Categories</span>
                </a>
                <a href="/admin/offers" class="nav-item">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                            <circle cx="15.5" cy="15.5" r="1.5"></circle>
                            <path d="M4.93 4.93l14.14 14.14"></path>
                        </svg>
                    </span>
                    <span class="nav-text">Offers</span>
                </a>
                <a href="/admin/settings" class="nav-item">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="3"></circle>
                            <path d="M19.4 15a7.38 7.38 0 000-6"></path>
                            <path d="M4.6 9a7.38 7.38 0 000 6"></path>
                            <path d="M9 4.6a7.38 7.38 0 016 0"></path>
                            <path d="M9 19.4a7.38 7.38 0 016 0"></path>
                        </svg>
                    </span>
                    <span class="nav-text">Settings</span>
                </a>
                <a href="/admin/banners" class="nav-item">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                            <path d="M8 21h8"></path>
                            <path d="M12 17v4"></path>
                        </svg>
                    </span>
                    <span class="nav-text">Banners</span>
                </a>
                <a href="/admin/coupons" class="nav-item">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 3h18"></path>
                            <path d="M7 10h10"></path>
                            <path d="M7 15h6"></path>
                            <rect x="5" y="6" width="14" height="14" rx="2"></rect>
                        </svg>
                    </span>
                    <span class="nav-text">Coupons</span>
                </a>
                <a href="/admin/logout" class="nav-item logout">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 17l5-5-5-5"></path>
                            <path d="M21 12H9"></path>
                            <path d="M4 4v16"></path>
                        </svg>
                    </span>
                    <span class="nav-text">Logout</span>
                </a>
            </nav>
        </aside>


        <main class="main-content">
            <div class="search-bar">
                <form action="/admin/users" method="GET">
                    <span class="search-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                    </span>
                    <input type="text" class="search-input" name="search" placeholder="Search for users" value="<%= search %>">
                </form>
            </div>

            <div class="header">
                <h1>Users</h1>
                <button class="btn-add-user">ADD USER +</button>
            </div>

            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>USER IMAGE</th>
                            <th>USER NAME</th>
                            <th>EMAIL</th>
                            <th>ADDRESS</th>
                            <th>DATE OF CREATION</th>
                            <th>ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (data.length > 0) { %>
                            <% for (let i = 0; i < data.length; i++) { %>
                                <tr>
                                    <td>
                                        <img src="<%= data[i].image %>" alt="<%= data[i].name %>" class="user-image">
                                    </td>
                                    <td><%= data[i].name %></td>
                                    <td><%= data[i].email %></td>
                                    <td><%= data[i].address %></td>
                                    <td><%= data[i].createdAt %></td>
                                    <td>
                                        <div class="action-buttons">
                                            <% if (data[i].isBlocked === false) { %>
                                                <a class="btn btn-danger" href="/admin/blockUser?id=<%= data[i]._id %>">
                                                    Block
                                                </a>
                                            <% } else { %>
                                                <a class="btn btn-success" href="/admin/unblockUser?id=<%= data[i]._id %>">
                                                    Unblock
                                                </a>
                                            <% } %>
                                            <a class="action-icon" href="/admin/editUser?id=<%= data[i]._id %>">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>
                                                </svg>
                                            </a>
                                            <a class="action-icon" href="/admin/deleteCustomer?id=<%= data[i]._id %>">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                                                </svg>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" style="text-align: center;">No users found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <div class="pagination-container">
                <div class="text-muted">SHOWING <%= currentPage %> OF <%= totalPages %></div>
                <nav>
                    <ul class="pagination">
                        <% if (currentPage > 1) { %>
                            <li class="page-item">
                                <a class="page-link" href="?page=<%= currentPage - 1 %>&search=<%= search %>">&lt;</a>
                            </li>
                        <% } %>
                        <% for (let i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= (i === currentPage) ? 'active' : '' %>">
                                <a class="page-link" href="?page=<%= i %>&search=<%= search %>"><%= i %></a>
                            </li>
                        <% } %>
                        <% if (currentPage < totalPages) { %>
                            <li class="page-item">
                                <a class="page-link" href="?page=<%= currentPage + 1 %>&search=<%= search %>">&gt;</a>
                            </li>
                        <% } %>
                    </ul>
                </nav>
            </div>
        </main>
    </div>
</body>
</html>