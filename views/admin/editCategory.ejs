                padding: 16px;
                background: #13151a;
                color: #9ca3af;
                font-weight: 500;
            }
    
            td {
                padding: 16px;
                border-bottom: 1px solid #374151;
            }
    
            .action-btn {
                background: none;
                border: none;
                color: #9ca3af;
                cursor: pointer;
                padding: 4px;
            }
    
            .pagination {
                display: flex;
                gap: 8px;
                justify-content: flex-end;
                margin-top: 24px;
            }
    
