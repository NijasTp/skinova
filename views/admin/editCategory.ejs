                background: #4fd1c5;
                color: #000;
            }
            .sidebar {
                width: 240px;
                background-color: #1a1d21;
                /* padding: 1.5rem 1rem; */
                height: 100vh;
                border-right: 1px solid #2d3139;
            }
    
            .logo {
                font-size: 1.75rem;
                font-weight: 500;
                color: #ffffff;
                margin-bottom: 3rem;
                padding-left: 0.5rem;
            }
    
            .nav-menu {
                display: flex;
                flex-direction: column;
            }
    
            .nav-item {
                display: flex;
                align-items: center;
                padding: 0.75rem 0.5rem;
                color: #6b7280;
                text-decoration: none;
                border-radius: 0.375rem;
                transition: all 0.2s;
                font-size: 1rem;
            }
    
            .nav-item:hover {
                background-color: rgba(255, 255, 255, 0.1);
            }
    
            .nav-item.active {
                color: #ffffff;
            }
    
            .nav-icon {
                display: flex;
                align-items: center;
                width: 24px;
                height: 24px;
                margin-right: 0.75rem;
            }
    
            .nav-icon svg {
                width: 20px;
                height: 20px;
            }
    
            .nav-item.logout {
                background-color: #ef4444;
                color: white;
                font-weight: bold;
            }
    
            .nav-item.logout:hover {
                background-color: #dc2626;
            }
    
        </style>
    </head>
