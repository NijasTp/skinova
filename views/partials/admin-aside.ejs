<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        /* Aside Styles */
        .aside {
            width: 240px;
            background-color: #1a1d21;
            padding: 1.5rem 1rem;
            height: 100vh;
            border-right: 1px solid #2d3139;
        }

        .aside .logo {
            font-size: 1.75rem;
            font-weight: 500;
            color: #ffffff;
            margin-bottom: 3rem;
            padding-left: 0.5rem;
        }

        .aside .nav-menu {
            display: flex;
            flex-direction: column;
        }

        .aside .nav-item {
            display: flex;
            align-items: center;
            padding: 0.75rem 0.5rem;
            color: #6b7280;
            text-decoration: none;
            border-radius: 0.375rem;
            transition: all 0.2s;
            font-size: 1rem;
        }

        .aside .nav-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }

        .aside .nav-item.active {
            color: #ffffff;
        }

        .aside .nav-icon {
            display: flex;
            align-items: center;
            width: 24px;
            height: 24px;
            margin-right: 0.75rem;
        }

        .aside .nav-icon svg {
            width: 20px;
            height: 20px;
        }

        .aside .nav-item.logout {
            background-color: #ef4444;
            color: white;
            font-weight: bold;
        }

        .aside .nav-item.logout:hover {
            background-color: #dc2626;
        }

        /* Logout Form Styles */
        .aside .logout-form {
            display: block;
            width: 100%;
            text-decoration: none;
            color: inherit;
        }

        .aside .logout-button {
            display: flex;
            align-items: center;
            width: 100%;
            padding: 0.75rem 0.5rem;
            background: none;
            border: none;
            color: inherit;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.2s;
        }

        .aside .logout-button:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }

        .aside .logout-button .nav-icon {
            margin-right: 0.75rem;
        }

        .aside .logout-button .nav-text {
            flex: 1;
        }
    </style>
</head>

<body>
    <aside class="sidebar">
        <div class="logo">Skinova</div>
        <nav class="nav-menu">
            <a href="/admin/dashboard" class="nav-item">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12l9-9 9 9"></path>
                        <path d="M4 10v10a2 2 0 002 2h4v-6h4v6h4a2 2 0 002-2V10"></path>
                    </svg>
                </span>
                <span class="nav-text">Dashboard</span>
            </a>
            <a href="/admin/products" class="nav-item">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                        <path d="M8 21h8"></path>
                        <path d="M12 17v4"></path>
                    </svg>
                </span>
                <span class="nav-text">Products</span>
            </a>
            <a href="/admin/orders" class="nav-item">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 3h18"></path>
                        <path d="M7 10h10"></path>
                        <path d="M7 15h6"></path>
                        <rect x="5" y="6" width="14" height="14" rx="2"></rect>
                    </svg>
                </span>
                <span class="nav-text">Orders</span>
            </a>
            <a href="/admin/users" class="nav-item">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="8" r="4"></circle>
                        <path d="M6 21v-2a4 4 0 014-4h4a4 4 0 014 4v2"></path>
                    </svg>
                </span>
                <span class="nav-text">Users</span>
            </a>
            <a href="/admin/categories" class="nav-item">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7"></rect>
                        <rect x="14" y="3" width="7" height="7"></rect>
                        <rect x="14" y="14" width="7" height="7"></rect>
                        <rect x="3" y="14" width="7" height="7"></rect>
                    </svg>
                </span>
                <span class="nav-text">Categories</span>
            </a>
            <a href="/admin/offers" class="nav-item">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="8.5" cy="8.5" r="1.5"></circle>
                        <circle cx="15.5" cy="15.5" r="1.5"></circle>
                        <path d="M4.93 4.93l14.14 14.14"></path>
                    </svg>
                </span>
                <span class="nav-text">Offers</span>
            </a>
            <a href="/admin/settings" class="nav-item">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a7.38 7.38 0 000-6"></path>
                        <path d="M4.6 9a7.38 7.38 0 000 6"></path>
                        <path d="M9 4.6a7.38 7.38 0 016 0"></path>
                        <path d="M9 19.4a7.38 7.38 0 016 0"></path>
                    </svg>
                </span>
                <span class="nav-text">Settings</span>
            </a>
            <a href="/admin/banners" class="nav-item">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                        <path d="M8 21h8"></path>
                        <path d="M12 17v4"></path>
                    </svg>
                </span>
                <span class="nav-text">Banners</span>
            </a>
            <a href="/admin/coupons" class="nav-item">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 3h18"></path>
                        <path d="M7 10h10"></path>
                        <path d="M7 15h6"></path>
                        <rect x="5" y="6" width="14" height="14" rx="2"></rect>
                    </svg>
                </span>
                <span class="nav-text">Coupons</span>
            </a>

            <!-- Logout Button as a POST Form -->
            <form action="/admin/logout" method="POST" class="nav-item logout-form">
                <button type="submit" class="logout-button">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 17l5-5-5-5"></path>
                            <path d="M21 12H9"></path>
                            <path d="M4 4v16"></path>
                        </svg>
                    </span>
                    <span class="nav-text">Logout</span>
                </button>
            </form>
        </nav>
    </aside>
</body>

</html>